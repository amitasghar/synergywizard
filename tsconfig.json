{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": false,
    "types": ["node"],
    "jsx": "react-jsx"
  },
  "include": ["netlify/**/*.ts", "db/**/*.ts", "tests/**/*.ts", "drizzle.config.ts", "src/**/*.ts", "src/**/*.tsx"]
}
